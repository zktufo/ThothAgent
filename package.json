{
  "name": "thoth-agent",
  "version": "1.0.0",
  "description": "A self-improving framework for domain-specific AI agents with layered memory, adaptive retrieval, and session-aware orchestration.",
  "main": "dist/cli/main.js",
  "type": "module",
  "bin": {
    "petagent": "bin/petagent.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node --disable-warning=ExperimentalWarning dist/cli/main.js",
    "dev": "tsc && node --disable-warning=ExperimentalWarning dist/cli/main.js",
    "typecheck": "tsc --noEmit",
    "memory:test": "npm run build && node dist/home/basic_test.js && node dist/model_manager/basic_test.js && node dist/session/basic_test.js && node dist/runtime/basic_test.js && node dist/memory/layered/basic_test.js && node dist/infra/basic_test.js && node dist/gateway/basic_test.js",
    "eval:memory-scale": "npm run build && node dist/evals/memory_scale_benchmark.js",
    "eval:memory-ab": "npm run build && node dist/evals/memory_ab_test.js"
  },
  "keywords": [
    "ai",
    "agent",
    "vertical-ai",
    "domain-specific",
    "memory",
    "retrieval",
    "session-orchestration",
    "self-improving",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@clack/prompts": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "ink": "^7.0.1",
    "openai": "^4.77.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
