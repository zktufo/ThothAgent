{
  "name": "pet-agent",
  "version": "1.0.0",
  "description": "🐾 毛孩子健康顾问 - 基于 MiniMax LLM 的宠物健康 AI 助手",
  "main": "dist/cli/main.js",
  "type": "module",
  "bin": {
    "petagent": "dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/main.js",
    "dev": "tsc && node dist/cli/main.js",
    "typecheck": "tsc --noEmit",
    "memory:test": "npm run build && node dist/home/basic_test.js && node dist/model_manager/basic_test.js && node dist/session/basic_test.js && node dist/runtime/basic_test.js && node dist/memory/layered/basic_test.js"
  },
  "keywords": [
    "pet",
    "health",
    "ai",
    "minimax",
    "agent",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@clack/prompts": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "ink": "^7.0.1",
    "openai": "^4.77.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
